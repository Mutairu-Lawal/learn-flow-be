{
	"name": "learn-flow-be",
	"version": "1.0.0",
	"description": "An Express js backend",
	"author": "Mutairu Lawal",
	"license": "MIT",
	"main": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "prisma generate && tsc && tsup",
		"start:dev": "node --import=tsx --watch src/index.ts",
		"start:prod": "node dist/index.js",
		"migrate": "prisma migrate deploy",
		"check": "biome check --write",
		"seed": "tsx src/lib/main.ts",
		"test": "cross-env NODE_ENV=test prisma generate && cross-env NODE_ENV=test vitest run",
		"test:watch": "cross-env NODE_ENV=test vitest",
		"test:cov": "cross-env NODE_ENV=test vitest run --coverage",
		"db:test:migrate": "cross-env NODE_ENV=test prisma generate && cross-env NODE_ENV=test prisma migrate deploy",
		"db:test:reset": "cross-env NODE_ENV=test prisma generate && cross-env NODE_ENV=test prisma migrate reset --force"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "7.3.4",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcrypt": "^6.0.0",
		"cors": "2.8.6",
		"dotenv": "17.3.1",
		"express": "5.2.1",
		"express-rate-limit": "8.3.1",
		"helmet": "8.1.0",
		"http-status-codes": "2.3.0",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.21.0",
		"pino": "9.14.0",
		"pino-http": "10.5.0",
		"swagger-ui-express": "5.0.1",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@faker-js/faker": "^10.5.0",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.3",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.20.0",
		"@types/supertest": "6.0.3",
		"@types/swagger-ui-express": "4.1.8",
		"@vitest/coverage-v8": "3.2.4",
		"cross-env": "^10.1.0",
		"pino-pretty": "13.1.3",
		"prisma": "^7.8.0",
		"supertest": "7.1.4",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.2",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.2.4"
	},
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"outDir": "dist",
		"format": [
			"esm",
			"cjs"
		],
		"target": "es2020",
		"sourcemap": true,
		"clean": true,
		"dts": true,
		"splitting": false,
		"skipNodeModulesBundle": true
	},
	"packageManager": "pnpm@10.33.0"
}
